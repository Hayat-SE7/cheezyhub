# Backend production env vars — add these in Railway dashboard
# (Project → Variables tab)

# Database (Neon production branch)
DATABASE_URL=postgresql://neondb_owner:PASSWORD@ep-XXXX-pooler.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15
DIRECT_URL=postgresql://neondb_owner:PASSWORD@ep-XXXX.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require

# Server
PORT=4000
NODE_ENV=production
CORS_ORIGIN=https://YOUR-FRONTEND.vercel.app

# Auth (generate with: openssl rand -base64 32)
JWT_SECRET=GENERATE_A_STRONG_SECRET_HERE
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# OTP
OTP_SECRET=GENERATE_A_HEX_SECRET_HERE
OTP_PROVIDER=stub
# For production OTP: OTP_PROVIDER=twilio_verify + add TWILIO_SID, TWILIO_TOKEN, TWILIO_VERIFY_SID

# WhatsApp
WHATSAPP_PROVIDER=stub
# For production WhatsApp: WHATSAPP_PROVIDER=twilio + add TWILIO_WHATSAPP_FROM

# Payments
PAYMENT_PROVIDER=stub
# For production Safepay: PAYMENT_PROVIDER=safepay + add SAFEPAY_SECRET_KEY, SAFEPAY_WEBHOOK_SECRET, SAFEPAY_ENVIRONMENT=production

# Frontend URL (for payment redirects)
FRONTEND_URL=https://YOUR-FRONTEND.vercel.app
