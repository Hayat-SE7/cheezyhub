# ─────────────────────────────────────────────────────
#  CheezyHub Backend — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env — it is gitignored.
# ─────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────
# Pooled URL for app queries (use with pgbouncer)
DATABASE_URL="postgresql://neondb_owner:YOUR_DB_PASSWORD@ep-your-project-pooler.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require&pgbouncer=true&connect_timeout=15"

# Direct URL for Prisma migrations
DIRECT_URL="postgresql://neondb_owner:YOUR_DB_PASSWORD@ep-your-project.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ─── Server ───────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ─── Auth ─────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=generate-with-openssl-rand-base64-32
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# ─── OTP (Phone Verification) ─────────────────────────
# Generate with: openssl rand -hex 32
OTP_SECRET=generate-with-openssl-rand-hex-32

# Provider: stub | twilio_verify | twilio_sms
OTP_PROVIDER=stub

# Twilio Verify (OTP_PROVIDER=twilio_verify) — recommended
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_auth_token
TWILIO_VERIFY_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio plain SMS (OTP_PROVIDER=twilio_sms)
# TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_TOKEN=your_auth_token
# TWILIO_SMS_FROM=+1xxxxxxxxxx

# ─── WhatsApp Notifications ───────────────────────────
# Provider: stub | twilio | meta
WHATSAPP_PROVIDER=stub

# Twilio WhatsApp (WHATSAPP_PROVIDER=twilio)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Meta Cloud API (WHATSAPP_PROVIDER=meta) — recommended for production
META_WHATSAPP_TOKEN=your_permanent_system_user_token
META_PHONE_NUMBER_ID=your_phone_number_id

# ─── Payments (Safepay) ───────────────────────────────
# Provider: stub | safepay
# Safepay covers: JazzCash, EasyPaisa, all Pakistani bank cards
PAYMENT_PROVIDER=stub

# Get from: getsafepay.com → Dashboard → Developers → API Keys
SAFEPAY_SECRET_KEY=sec_test_xxxxxxxxxxxxxxxxxxxx

# "sandbox" for testing, "production" for live
SAFEPAY_ENVIRONMENT=sandbox

# Get from: getsafepay.com → Dashboard → Developers → Webhooks
SAFEPAY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ─── URLs ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
