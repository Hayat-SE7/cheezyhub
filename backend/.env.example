# ─────────────────────────────────────────────────────
#  CheezyHub Backend — Environment Variables  v6.1
#  Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────

# ─── Database ────────────────────────────────────────
# ─── Database ────────────────────────────────────────
# Pooled URL for your Backend/Next.js app
# backend/.env

DATABASE_URL="postgresql://neondb_owner:npg_vJE2ki0aKFhf@ep-red-cherry-aieka6xp-pooler.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ─── Server ──────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ─── Auth ────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=GlEKlZjLhVENFFI0wXwBexRS0pFXiUH1I8hjRB0+z0w=
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# ─── OTP (Phone Verification) ────────────────────────
# Generate with: openssl rand -hex 32
OTP_SECRET=change-me-to-a-random-hex-string

# Provider: stub | twilio_verify | twilio_sms
OTP_PROVIDER=stub

# Twilio Verify (OTP_PROVIDER=twilio_verify) — recommended
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_auth_token
TWILIO_VERIFY_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio plain SMS (OTP_PROVIDER=twilio_sms)
# TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_TOKEN=your_auth_token
# TWILIO_SMS_FROM=+1xxxxxxxxxx

# ─── WhatsApp Notifications ──────────────────────────
# Provider: stub | twilio | meta
WHATSAPP_PROVIDER=stub

# Twilio WhatsApp (WHATSAPP_PROVIDER=twilio)
# Get sandbox number from: twilio.com → Messaging → Try it out → WhatsApp
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Meta Cloud API (WHATSAPP_PROVIDER=meta) — recommended for production
# Setup: developers.facebook.com → Create App → WhatsApp
META_WHATSAPP_TOKEN=your_permanent_system_user_token
META_PHONE_NUMBER_ID=your_phone_number_id

# ─── Payments (Safepay) ──────────────────────────────
# Provider: stub | safepay
# Safepay covers: JazzCash, EasyPaisa, all Pakistani bank cards
PAYMENT_PROVIDER=stub

# Get from: getsafepay.com → Dashboard → Developers → API Keys
SAFEPAY_SECRET_KEY=sec_test_xxxxxxxxxxxxxxxxxxxx

# "sandbox" for testing, "production" for live
SAFEPAY_ENVIRONMENT=sandbox

# Get from: getsafepay.com → Dashboard → Developers → Webhooks
# (shown once after you save the webhook endpoint)
SAFEPAY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Frontend URL (for Safepay redirect after payment)
FRONTEND_URL=http://localhost:3000

# ─── Payments (Safepay) ──────────────────────────────
# Provider: stub | safepay
PAYMENT_PROVIDER=stub

# Safepay (PAYMENT_PROVIDER=safepay)
# Sign up: getsafepay.com → Dashboard → Developers → API Keys
# Sandbox base URL: https://sandbox.api.getsafepay.com
# Production base URL: https://api.getsafepay.com
# Test card: Visa 4111 1111 1111 1111  CVV: 123  Exp: any future date
SAFEPAY_SECRET_KEY=your_safepay_secret_key
SAFEPAY_WEBHOOK_SECRET=your_safepay_webhook_secret
# sandbox | production
SAFEPAY_ENVIRONMENT=sandbox

# Frontend URL — Safepay redirects here after payment
FRONTEND_URL=http://localhost:3000
